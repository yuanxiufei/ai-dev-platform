# ==========================================
# AI Fullstack Platform — 后端环境变量模板
# 复制为 .env 并填入实际值
# ==========================================

# ── 基础配置 ──
PROJECT_NAME=AI Fullstack Platform
ENVIRONMENT=local
SECRET_KEY=changethis_to_a_random_secret_key
ACCESS_TOKEN_EXPIRE_MINUTES=11520
FRONTEND_HOST=http://localhost:5173

# ── 数据库 ──
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis
POSTGRES_DB=app

# ── 邮件 (SMTP) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
EMAILS_FROM_NAME=AI Fullstack Platform

# 初始化超级管理员
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# ── AI 模型配置 ──
MODELS_DIR=models
DEFAULT_MODEL=gemma-31b
MODEL_PREFER_LOCAL=true

# ── 第三方 API 密钥 ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
AZURE_OPENAI_API_KEY=
REPLICATE_API_KEY=
ZHIPU_API_KEY=
QWEN_API_KEY=

# ── 模型调度 ──
MODEL_REQUEST_TIMEOUT=30
MODEL_MAX_RETRIES=2
MODEL_FALLBACK_ENABLED=true
AUTO_OPTIMIZE_ENABLED=true
AUTO_OPTIMIZE_INTERVAL_HOURS=24

# ── RAG / 知识库 ──
KB_SQLITE_PATH=data/kb_metadata.db

# ── 图像生成 ──
STABILITY_API_KEY=
COMFYUI_BASE_URL=

# ── Web 搜索 ──
TAVILY_API_KEY=
BRAVE_API_KEY=
FIRECRAWL_API_KEY=

# ── Redis ──
REDIS_ENABLED=false
REDIS_URL=

# ── Celery 后台任务 ──
TASK_QUEUE_ENABLED=false
CELERY_BROKER_URL=

# ── Sentry ──
SENTRY_DSN=

# ── Standalone 模式 ──
STANDALONE_MODE=false
STANDALONE_BIND_PORT=18000
